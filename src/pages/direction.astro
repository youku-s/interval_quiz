---
import Layout from '../layouts/Layout.astro';
---
<Layout title="音程方向クイズ" activeTab="direction" mainGap="gap-3" wide>
  <header class="flex justify-between items-center">
    <h1 class="text-xl font-bold">音程方向クイズ</h1>
    <div class="flex items-center gap-4">
      <button id="copyBtn" disabled class="export-btn">📋 MD コピー</button>
      <button id="downloadBtn" disabled class="export-btn">⬇ MD DL</button>
      <button id="csvBtn" class="export-btn">⬇ CSV DL</button>
      <div class="text-sm text-slate-400 text-right leading-snug">
        <span class="text-lg font-bold text-slate-200">
          <span id="correct">0</span> / <span id="total">0</span>
        </span><br />正解
      </div>
    </div>
  </header>

  <div class="flex gap-4 items-start">
    <!-- 左カラム：クイズ + 回答ボタン -->
    <div class="flex flex-col gap-3 shrink-0" style="width:268px">
      <section class="bg-slate-800 border border-slate-700 rounded-xl p-3 flex flex-col gap-2">
        <label class="flex items-center gap-2 text-sm text-slate-400">
          ルート音
          <select id="baseNoteSelect" class="bg-slate-900 text-slate-200 border border-slate-700 rounded px-2 py-1 text-sm"></select>
        </label>
        <label class="flex items-center gap-2 text-sm text-slate-400">
          方向
          <select id="directionSelect" class="bg-slate-900 text-slate-200 border border-slate-700 rounded px-2 py-1 text-sm">
            <option value="random">ランダム</option>
            <option value="up">上行のみ</option>
            <option value="down">下行のみ</option>
          </select>
        </label>
        <label class="flex items-center gap-2 text-sm text-slate-400">
          範囲
          <span class="text-xs text-slate-500">0 〜</span>
          <input id="rangeMax" type="number" min="1" max="12" value="12"
            class="bg-slate-900 text-slate-200 border border-slate-700 rounded px-1.5 py-1 text-sm w-12 text-center">
          <span class="text-xs text-slate-500">st</span>
        </label>

        <div class="flex gap-2">
          <button id="playBtn" class="bg-blue-500 text-white font-semibold px-5 py-2 rounded-lg text-base transition-colors">▶ 再生</button>
          <button id="replayBtn" class="bg-slate-700 text-slate-200 px-5 py-2 rounded-lg text-base transition-colors" disabled>↩ もう一度</button>
        </div>

        <p id="status" class="status text-sm text-slate-400 text-center">「再生」を押して問題を聞いてください</p>
      </section>

      <div class="grid grid-cols-2 gap-2">
        <div class="flex flex-col gap-1">
          <div id="up-header" class="text-center text-xs font-bold text-slate-400 bg-slate-900 border border-slate-700 rounded py-1 transition-opacity">↑ 上行</div>
          <div id="up-answers"></div>
        </div>
        <div class="flex flex-col gap-1">
          <div id="down-header" class="text-center text-xs font-bold text-slate-400 bg-slate-900 border border-slate-700 rounded py-1 transition-opacity">↓ 下行</div>
          <div id="down-answers"></div>
        </div>
      </div>
      <div id="unison-answer" class="mt-1"></div>
    </div>

    <!-- 右カラム：成績 + 診断 -->
    <div class="flex flex-col gap-3 flex-1 min-w-0">
      <div class="grid grid-cols-2 gap-3">

        <!-- 音程別成績 -->
        <section class="bg-slate-800 border border-slate-700 rounded-xl p-3">
          <h2 class="text-xs font-bold text-slate-400 uppercase tracking-wide mb-2">音程別成績</h2>
          <div id="stats-table"></div>
        </section>

        <!-- 診断 -->
        <section class="bg-slate-800 border border-slate-700 rounded-xl p-3">
          <h2 class="text-xs font-bold text-slate-400 uppercase tracking-wide mb-2">診断</h2>
          <p id="diagnosis" class="text-sm text-slate-500">5問以上回答すると傾向が表示されます</p>
        </section>

      </div>
    </div>
  </div>

  <!-- 推移グラフ（全幅） -->
  <section class="bg-slate-800 border border-slate-700 rounded-xl p-3">
    <h2 class="text-xs font-bold text-slate-400 uppercase tracking-wide mb-2">推移グラフ</h2>
    <p id="chart-empty" class="text-xs text-slate-500">回答するとグラフが表示されます</p>
    <canvas id="history-chart" width="600" height="180" style="display:none;width:100%;height:auto;border-radius:0.2rem"></canvas>
    <div id="chart-legend" style="display:none" class="flex gap-3 mt-1.5 text-xs text-slate-500">
      <span><span style="color:#16a34a">●</span> 正解</span>
      <span><span style="color:#ef4444">●</span> 誤答</span>
    </div>
  </section>
</Layout>

<style is:global>
  /* ---- エクスポートボタン ---- */
  .export-btn {
    font-size: 0.75rem;
    padding: 0.35rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid #334155;
    background: #0f172a;
    color: #38bdf8;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
    font-family: inherit;
  }
  .export-btn:hover:not(:disabled) { background: #1e3a5f; border-color: #38bdf8; }
  .export-btn:disabled {
    background: #1e293b;
    color: #334155;
    border-color: #1e293b;
    cursor: default;
  }

  /* ---- 回答ボタン ---- */
  .dir-btn {
    background: #1e293b;
    border: 1px solid #334155;
    color: #e2e8f0;
    padding: 0.2rem 0.4rem;
    border-radius: 0.3rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: background 0.12s, border-color 0.12s;
    width: 100%;
    font-family: inherit;
    cursor: pointer;
  }
  .dir-btn:hover:not(:disabled) { background: #334155; border-color: #3b82f6; }
  .dir-btn .arrow { font-size: 0.75rem; }
  .dir-btn .semi  { font-size: 0.85rem; font-weight: 700; font-family: monospace; }
  .dir-btn .note  { font-size: 0.75rem; color: #64748b; margin-left: auto; font-family: monospace; }
  .dir-btn.correct { background: #052e16; border-color: #22c55e; color: #22c55e; }
  .dir-btn.correct .note { color: #16a34a; }
  .dir-btn.wrong   { background: #450a0a; border-color: #ef4444; color: #ef4444; }
  .dir-btn.wrong .note { color: #b91c1c; }
  .dir-btn.out-of-play {
    opacity: 0.2;
    background: #0f172a;
    border-color: #1e293b;
    color: #1e293b;
    cursor: not-allowed;
  }
  .dir-btn.out-of-play .note { color: #1e293b; }


  /* ---- 成績テーブル ---- */
  .stats-tbl { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  .stats-tbl th { color: #64748b; font-weight: 600; text-align: left; padding: 0.1rem 0.35rem 0.25rem; border-bottom: 1px solid #334155; font-size: 0.7rem; }
  .stats-tbl td { padding: 0.1rem 0.35rem; color: #64748b; }
  .stats-tbl .td-st { color: #e2e8f0; font-weight: 700; font-family: monospace; }
  .stats-tbl .td-name { color: #475569; }
  .stats-tbl tbody tr:hover { background: rgba(255,255,255,0.03); }
  .stats-tbl .stat-good { color: #22c55e; }
  .stats-tbl .stat-mid  { color: #e2e8f0; }
  .stats-tbl .stat-bad  { color: #ef4444; }

  /* ---- 診断 ---- */
  .diag-line { margin: 0.2rem 0; color: #cbd5e1; font-size: 0.85rem; }
</style>

<script>
  import {
    ALL_INTERVALS,
    BASE_NOTE_OPTIONS,
    type Interval,
    pickRandom,
    resolveBaseMidi,
  } from '../lib/intervals';
  import { playInterval } from '../lib/audio';

  const QUIZ_INTERVALS = ALL_INTERVALS.filter(iv => iv.semitones > 0);  // 1〜12
  const UNISON_IV      = ALL_INTERVALS.find(iv => iv.semitones === 0)!; // 同音

  // ---- 音名変換 ----
  const NOTE_NAMES = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B'];
  function midiToNoteName(midi: number): string {
    const pc = ((midi % 12) + 12) % 12;
    const octave = Math.floor(midi / 12) - 1;
    return `${NOTE_NAMES[pc]}${octave}`;
  }

  // ---- クイズ状態 ----
  let currentSemitones = 0;
  let currentBaseMidi  = 60;
  let isPlaying  = false;
  let answered   = false;
  let correct    = 0;
  let total      = 0;

  // ---- localStorage スキーマ ----
  interface QuizRecord {
    schemaVersion: 2;
    id: string;
    sessionId: string;
    playedAt: number;       // 初回再生 epoch ms
    lastPlayedAt: number;   // 最後の再生 epoch ms
    answeredAt: number;     // 回答 epoch ms
    responseTimeMs: number; // lastPlayedAt → answeredAt
    replayCount: number;
    baseMidi: number;
    baseNote: string;       // ルート音名 e.g. "C4"
    directionMode: string;  // "random" | "up" | "down"
    rangeMin: number;       // 出題範囲 最小 semitone
    rangeMax: number;       // 出題範囲 最大 semitone
    correctSt: number;
    answeredSt: number;
    ok: boolean;
  }
  const STORAGE_KEY = 'interval_quiz_records_v1';
  const sessionId = Date.now().toString(36) + Math.random().toString(36).slice(2, 6);

  function loadRecords(): QuizRecord[] {
    try {
      const raw: any[] = JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '[]');
      return raw.map(r => r.schemaVersion === 1
        ? { ...r, schemaVersion: 2, rangeMin: 0, rangeMax: 12 } as QuizRecord
        : r as QuizRecord);
    } catch { return []; }
  }
  function saveRecord(rec: QuizRecord): void {
    const all = loadRecords();
    all.push(rec);
    localStorage.setItem(STORAGE_KEY, JSON.stringify(all));
  }

  // ---- 解析状態（セッション中のみ） ----
  type HistoryEntry = {
    correctSt: number; answeredSt: number; ok: boolean;
    baseMidi: number; directionMode: string; rangeMax: number;
  };
  const history: HistoryEntry[] = [];
  // signed semitone → { ok, total }
  const statMap = new Map<number, { ok: number; total: number }>();
  // "correctSt→answeredSt" → count
  const confusions = new Map<string, number>();

  // ---- 出題範囲（rangeMin は常に 0 = 同音込み） ----
  const rangeMin = 0;
  let rangeMax = 12;

  // ---- タイミング追跡 ----
  let currentPlayedAt     = 0;
  let currentLastPlayedAt = 0;
  let currentReplayCount  = 0;

  // ---- 回答ボタン有効状態 ----
  let answersEnabled = false;

  // ---- DOM参照 ----
  const playBtn        = document.getElementById('playBtn')        as HTMLButtonElement;
  const replayBtn      = document.getElementById('replayBtn')      as HTMLButtonElement;
  const statusEl       = document.getElementById('status')         as HTMLParagraphElement;
  const correctEl      = document.getElementById('correct')        as HTMLSpanElement;
  const totalEl        = document.getElementById('total')          as HTMLSpanElement;
  const copyBtn           = document.getElementById('copyBtn')           as HTMLButtonElement;
  const downloadBtn       = document.getElementById('downloadBtn')       as HTMLButtonElement;
  const csvBtn            = document.getElementById('csvBtn')            as HTMLButtonElement;
  const baseNoteSelect    = document.getElementById('baseNoteSelect')    as HTMLSelectElement;
  const directionSelect   = document.getElementById('directionSelect')   as HTMLSelectElement;
  const upAnswers      = document.getElementById('up-answers')     as HTMLDivElement;
  const downAnswers    = document.getElementById('down-answers')   as HTMLDivElement;
  const unisonAnswer   = document.getElementById('unison-answer')  as HTMLDivElement;
  const upHeader       = document.getElementById('up-header')      as HTMLDivElement;
  const downHeader     = document.getElementById('down-header')    as HTMLDivElement;
  const rangeMaxInput  = document.getElementById('rangeMax')       as HTMLInputElement;

  for (const opt of BASE_NOTE_OPTIONS) {
    const el = document.createElement('option');
    el.value = opt.midi === null ? 'random' : String(opt.midi);
    el.textContent = opt.label;
    if (opt.midi === 60) el.selected = true;
    baseNoteSelect.appendChild(el);
  }

  // ---- 回答ボタン生成 ----
  function makeButtons(container: HTMLDivElement, sign: 1 | -1): void {
    container.style.cssText = 'display:flex;flex-direction:column;gap:0.15rem';
    for (const iv of QUIZ_INTERVALS) {
      const signed = sign * iv.semitones;
      const btn = document.createElement('button');
      btn.className = 'dir-btn';
      btn.dataset.semitones = String(signed);
      btn.disabled = true;
      btn.innerHTML =
        `<span class="arrow">${sign === 1 ? '↑' : '↓'}</span>` +
        `<span class="semi">${iv.semitones}</span>` +
        `<span class="note"></span>`;
      btn.addEventListener('click', () => onAnswer(signed));
      container.appendChild(btn);
    }
  }

  makeButtons(upAnswers,   1);
  makeButtons(downAnswers, -1);

  // 同音ボタン（方向なし）
  function makeUnisonButton(): void {
    unisonAnswer.style.cssText = 'display:flex;justify-content:center';
    const btn = document.createElement('button');
    btn.className = 'dir-btn';
    btn.dataset.semitones = '0';
    btn.disabled = true;
    btn.style.cssText = 'width:100%';
    btn.innerHTML =
      `<span class="arrow">→</span>` +
      `<span class="semi">0</span>` +
      `<span style="font-size:0.75rem;color:#64748b;margin-left:0.3rem">P1</span>` +
      `<span class="note"></span>`;
    btn.addEventListener('click', () => onAnswer(0));
    unisonAnswer.appendChild(btn);
  }
  makeUnisonButton();

  // ---- 出題範囲フィルタ ----
  function getActiveIntervals(): typeof QUIZ_INTERVALS[0][] {
    const ranged = QUIZ_INTERVALS.filter(iv => iv.semitones >= rangeMin && iv.semitones <= rangeMax);
    return [UNISON_IV, ...ranged];
  }

  function updateButtonNotes(baseMidi: number): void {
    for (const btn of allButtons()) {
      const signed = Number(btn.dataset.semitones);
      const noteEl = btn.querySelector<HTMLSpanElement>('.note');
      if (noteEl) noteEl.textContent = midiToNoteName(baseMidi + signed);
    }
  }


  function allButtons(): HTMLButtonElement[] {
    return [
      ...upAnswers.querySelectorAll<HTMLButtonElement>('.dir-btn'),
      ...downAnswers.querySelectorAll<HTMLButtonElement>('.dir-btn'),
      ...unisonAnswer.querySelectorAll<HTMLButtonElement>('.dir-btn'),
    ];
  }

  function isButtonConstrained(btn: HTMLButtonElement): boolean {
    const signed = Number(btn.dataset.semitones);
    if (signed === 0) return false; // 同音は常に有効
    const abs = Math.abs(signed);
    const dirMode = directionSelect.value;
    const inRange = abs >= rangeMin && abs <= rangeMax;
    const dirOk   = dirMode === 'random'
      || (dirMode === 'up'   && signed > 0)
      || (dirMode === 'down' && signed < 0);
    return !inRange || !dirOk;
  }

  function applyButtonDisabledState(): void {
    for (const btn of allButtons()) {
      btn.disabled = !answersEnabled || isButtonConstrained(btn);
    }
  }

  function setAnswerButtonsDisabled(disabled: boolean): void {
    answersEnabled = !disabled;
    applyButtonDisabledState();
  }

  function updateButtonConstraints(): void {
    for (const btn of allButtons()) {
      btn.classList.toggle('out-of-play', isButtonConstrained(btn));
    }
    applyButtonDisabledState();
    const dirMode = directionSelect.value;
    upHeader.classList.toggle('opacity-25', dirMode === 'down');
    downHeader.classList.toggle('opacity-25', dirMode === 'up');
  }

  function resetAnswerButtons(): void {
    for (const btn of allButtons()) {
      btn.className = 'dir-btn';
      btn.classList.toggle('out-of-play', isButtonConstrained(btn));
    }
  }

  function getSelectedBaseMidi(): number {
    const val = baseNoteSelect.value;
    return resolveBaseMidi(val === 'random' ? null : Number(val));
  }

  // ---- 再生 ----
  async function play(semitones: number, baseMidi: number): Promise<void> {
    currentLastPlayedAt = Date.now();
    isPlaying = true;
    playBtn.disabled = true;
    replayBtn.disabled = true;
    setAnswerButtonsDisabled(true);
    statusEl.textContent = '再生中...';
    statusEl.className = 'status playing text-sm text-center';

    await playInterval(semitones, baseMidi, 'ascending');

    isPlaying = false;
    statusEl.textContent = '上行？下行？セミトーン数は？';
    statusEl.className = 'status listening text-sm text-center';
    setAnswerButtonsDisabled(false);
    replayBtn.disabled = false;
  }

  async function newQuestion(): Promise<void> {
    answered = false;
    resetAnswerButtons();
    currentPlayedAt = Date.now();
    currentReplayCount = 0;

    const dirMode = directionSelect.value;
    const iv: Interval = pickRandom(getActiveIntervals());
    if (iv.semitones === 0) {
      currentSemitones = 0;
    } else {
      const direction: 1 | -1 = dirMode === 'up' ? 1 : dirMode === 'down' ? -1 : (Math.random() < 0.5 ? 1 : -1);
      currentSemitones = direction * iv.semitones;
    }
    currentBaseMidi  = getSelectedBaseMidi();
    updateButtonNotes(currentBaseMidi);

    await play(currentSemitones, currentBaseMidi);
  }

  // ---- 解答 ----
  function onAnswer(selected: number): void {
    if (answered || isPlaying) return;

    answered = true;
    total++;
    setAnswerButtonsDisabled(true);
    replayBtn.disabled = true;

    const isCorrect = selected === currentSemitones;
    if (isCorrect) correct++;

    correctEl.textContent = String(correct);
    totalEl.textContent   = String(total);

    for (const btn of allButtons()) {
      const s = Number(btn.dataset.semitones);
      if (s === currentSemitones)           btn.classList.add('correct');
      else if (s === selected && !isCorrect) btn.classList.add('wrong');
    }

    statusEl.textContent = '「再生」を押して次の問題へ';
    statusEl.className   = 'status text-sm text-slate-400 text-center';
    playBtn.disabled = false;

    recordAnswer(currentSemitones, selected, isCorrect);
  }

  // ---- 解析：記録 ----
  function recordAnswer(correctSt: number, answeredSt: number, ok: boolean): void {
    history.push({ correctSt, answeredSt, ok, baseMidi: currentBaseMidi, directionMode: directionSelect.value, rangeMax });
    if (history.length === 1) { copyBtn.disabled = false; downloadBtn.disabled = false; }

    const answeredAt = Date.now();
    saveRecord({
      schemaVersion: 2,
      id: answeredAt.toString(36) + Math.random().toString(36).slice(2, 6),
      sessionId,
      playedAt: currentPlayedAt,
      lastPlayedAt: currentLastPlayedAt,
      answeredAt,
      responseTimeMs: answeredAt - currentLastPlayedAt,
      replayCount: currentReplayCount,
      baseMidi: currentBaseMidi,
      baseNote: midiToNoteName(currentBaseMidi),
      directionMode: directionSelect.value,
      rangeMin,
      rangeMax,
      correctSt,
      answeredSt,
      ok,
    });

    const s = statMap.get(correctSt) ?? { ok: 0, total: 0 };
    s.total++;
    if (ok) s.ok++;
    statMap.set(correctSt, s);

    if (!ok) {
      const key = `${correctSt}→${answeredSt}`;
      confusions.set(key, (confusions.get(key) ?? 0) + 1);
    }

    renderChart();
    renderStats();
    renderDiagnosis();
  }

  // ---- 解析：推移グラフレンダリング ----
  function renderChart(): void {
    const emptyEl  = document.getElementById('chart-empty')  as HTMLElement;
    const canvas   = document.getElementById('history-chart') as HTMLCanvasElement;
    const legendEl = document.getElementById('chart-legend')  as HTMLElement;

    if (history.length === 0) return;
    emptyEl.style.display  = 'none';
    canvas.style.display   = 'block';
    legendEl.style.display = 'flex';

    const entries = history.slice(-20);
    const n = entries.length;
    const W = 600, H = 180;
    const PAD = { t: 10, b: 18, l: 26, r: 6 };
    const pw = W - PAD.l - PAD.r, ph = H - PAD.t - PAD.b;
    const xOf = (i: number) => PAD.l + (n <= 1 ? pw / 2 : i / (n - 1) * pw);
    const yOf = (st: number) => PAD.t + (1 - (st + 12) / 24) * ph;

    const c = canvas.getContext('2d')!;
    c.clearRect(0, 0, W, H);

    // グリッド線
    for (const st of [-12, -6, 0, 6, 12]) {
      c.strokeStyle = st === 0 ? '#334155' : '#1e293b';
      c.lineWidth   = st === 0 ? 1 : 0.5;
      if (st === 0) c.setLineDash([4, 4]);
      c.beginPath(); c.moveTo(PAD.l, yOf(st)); c.lineTo(W - PAD.r, yOf(st)); c.stroke();
      c.setLineDash([]);
    }

    // Y軸ラベル
    c.fillStyle = '#475569'; c.font = '9px monospace';
    c.textAlign = 'right'; c.textBaseline = 'middle';
    for (const [st, lbl] of [[-12,'-12'],[-6,'-6'],[0,'0'],[6,'+6'],[12,'+12']] as [number,string][]) {
      c.fillText(lbl, PAD.l - 3, yOf(st));
    }

    // 正解の折れ線
    if (n >= 2) {
      c.strokeStyle = '#16a34a'; c.lineWidth = 1.5;
      c.beginPath();
      entries.forEach((e, i) => { i === 0 ? c.moveTo(xOf(i), yOf(e.correctSt)) : c.lineTo(xOf(i), yOf(e.correctSt)); });
      c.stroke();
    }

    // 誤答の縦の差分線
    entries.forEach((e, i) => {
      if (!e.ok) {
        c.strokeStyle = '#4b5563'; c.lineWidth = 1; c.setLineDash([2, 2]);
        c.beginPath(); c.moveTo(xOf(i), yOf(e.correctSt)); c.lineTo(xOf(i), yOf(e.answeredSt)); c.stroke();
        c.setLineDash([]);
      }
    });

    // ドット
    entries.forEach((e, i) => {
      const x = xOf(i);
      c.fillStyle = '#16a34a';
      c.beginPath(); c.arc(x, yOf(e.correctSt), 3, 0, Math.PI * 2); c.fill();
      if (!e.ok) {
        c.fillStyle = '#ef4444';
        c.beginPath(); c.arc(x, yOf(e.answeredSt), 3, 0, Math.PI * 2); c.fill();
      }
    });
  }

  // ---- 解析：成績テーブルレンダリング ----
  function fmtStat(st: number): { text: string; cls: string } {
    const s = statMap.get(st);
    if (!s || s.total === 0) return { text: '−', cls: '' };
    const pct = Math.round(s.ok / s.total * 100);
    const cls = pct >= 70 ? 'stat-good' : pct < 50 ? 'stat-bad' : 'stat-mid';
    return { text: `${s.ok}/${s.total} ${pct}%`, cls };
  }

  function renderStats(): void {
    const tableEl = document.getElementById('stats-table')!;
    const rows = QUIZ_INTERVALS.map(iv => {
      const up = fmtStat(+iv.semitones);
      const dn = fmtStat(-iv.semitones);
      return `<tr>
        <td class="td-st">${iv.semitones}</td>
        <td class="td-name">${iv.shortName}</td>
        <td class="${up.cls}">${up.text}</td>
        <td class="${dn.cls}">${dn.text}</td>
      </tr>`;
    }).join('');

    const uniStat = fmtStat(0);
    const uniRow = `<tr>
      <td class="td-st">0</td>
      <td class="td-name" colspan="2">P1 同音</td>
      <td class="${uniStat.cls}">${uniStat.text}</td>
    </tr>`;
    tableEl.innerHTML = `<table class="stats-tbl">
      <thead><tr><th>St</th><th></th><th>↑ 上行</th><th>↓ 下行</th></tr></thead>
      <tbody>${uniRow}${rows}</tbody>
    </table>`;
  }

  // ---- 解析：診断レンダリング ----
  function renderDiagnosis(): void {
    const diagEl = document.getElementById('diagnosis')!;
    if (history.length < 5) return;

    const lines: string[] = [];

    // 方向別正解率
    let upOk = 0, upTotal = 0, dnOk = 0, dnTotal = 0;
    for (const iv of QUIZ_INTERVALS) {
      const u = statMap.get(+iv.semitones);
      const d = statMap.get(-iv.semitones);
      if (u) { upOk += u.ok; upTotal += u.total; }
      if (d) { dnOk += d.ok; dnTotal += d.total; }
    }
    if (upTotal >= 3 && dnTotal >= 3) {
      const upPct = Math.round(upOk / upTotal * 100);
      const dnPct = Math.round(dnOk / dnTotal * 100);
      const diff = upPct - dnPct;
      if (Math.abs(diff) >= 15) {
        lines.push(diff > 0
          ? `↑上行の方が得意です（上行 ${upPct}% / 下行 ${dnPct}%）`
          : `↓下行の方が得意です（下行 ${dnPct}% / 上行 ${upPct}%）`);
      } else {
        lines.push(`上行・下行のバランスが良いです（上行 ${upPct}% / 下行 ${dnPct}%）`);
      }
    }

    // 苦手・得意
    const weak: string[] = [], strong: string[] = [];
    for (const iv of QUIZ_INTERVALS) {
      for (const [dirLabel, sign] of [['↑', 1], ['↓', -1]] as const) {
        const s = statMap.get(sign * iv.semitones);
        if (!s || s.total < 3) continue;
        const pct = s.ok / s.total;
        if (pct < 0.5)   weak.push(`${dirLabel}${iv.semitones}(${iv.shortName})`);
        else if (pct === 1) strong.push(`${dirLabel}${iv.semitones}(${iv.shortName})`);
      }
    }
    if (weak.length)   lines.push(`苦手: ${weak.join('、')}`);
    if (strong.length) lines.push(`得意: ${strong.join('、')}`);

    // 混同しやすい組み合わせ
    const topConfusions = [...confusions.entries()]
      .sort((a, b) => b[1] - a[1])
      .slice(0, 2);
    if (topConfusions.length) {
      const parts = topConfusions.map(([key, n]) => {
        const [c, a] = key.split('→').map(Number);
        return `${c > 0 ? '↑' : '↓'}${Math.abs(c)}を${a > 0 ? '↑' : '↓'}${Math.abs(a)}と混同(${n}回)`;
      });
      lines.push(`混同: ${parts.join('、')}`);
    }

    diagEl.innerHTML = lines.map(l => `<p class="diag-line">・${l}</p>`).join('');
  }

  // ---- エクスポート ----
  function fmtStatMd(st: number): string {
    const s = statMap.get(st);
    if (!s || s.total === 0) return '−';
    return `${s.ok}/${s.total} (${Math.round(s.ok / s.total * 100)}%)`;
  }

  function generateMarkdown(): string {
    const lines: string[] = [];
    const pct = total > 0 ? Math.round(correct / total * 100) : 0;
    const now = new Date().toLocaleString('ja-JP');

    lines.push('# 音程方向クイズ 結果レポート');
    lines.push(`> エクスポート日時: ${now}`);
    lines.push('');
    lines.push('## 概要');
    lines.push(`- 正解率: **${correct} / ${total} (${pct}%)**`);
    lines.push('');

    lines.push('## 音程別成績');
    lines.push('| 半音 | 音程名 | ↑ 上行 | ↓ 下行 |');
    lines.push('|:----:|--------|--------|--------|');
    lines.push(`| 0 | P1 同音 | ${fmtStatMd(0)} | − |`);
    for (const iv of QUIZ_INTERVALS) {
      lines.push(`| ${iv.semitones} | ${iv.shortName} (${iv.jaName}) | ${fmtStatMd(+iv.semitones)} | ${fmtStatMd(-iv.semitones)} |`);
    }
    lines.push('');

    if (history.length > 0) {
      const dirLabel = (mode: string) =>
        mode === 'up' ? '上行のみ' : mode === 'down' ? '下行のみ' : 'ランダム';
      lines.push('## 回答履歴');
      lines.push('| # | ルート音 | 範囲 | 方向設定 | 正解 | 正解音 | 正誤 | 回答 |');
      lines.push('|--:|--------|------|---------|------|--------|:----:|------|');
      history.forEach((e, i) => {
        const abs  = Math.abs(e.correctSt);
        const dir  = e.correctSt > 0 ? '↑' : e.correctSt < 0 ? '↓' : '→';
        const iv   = ALL_INTERVALS.find(v => v.semitones === abs) ?? UNISON_IV;
        const note = midiToNoteName(e.baseMidi + e.correctSt);
        const ans  = e.ok ? '−' : (() => {
          const aabs  = Math.abs(e.answeredSt);
          const adir  = e.answeredSt > 0 ? '↑' : e.answeredSt < 0 ? '↓' : '→';
          const anote = midiToNoteName(e.baseMidi + e.answeredSt);
          return `${adir}${aabs} ${anote}`;
        })();
        lines.push(`| ${i + 1} | ${midiToNoteName(e.baseMidi)} | 0〜${e.rangeMax} | ${dirLabel(e.directionMode)} | ${dir}${abs} ${iv.shortName} | ${note} | ${e.ok ? '✓' : '✗'} | ${ans} |`);
      });
      lines.push('');
    }

    const diagEl = document.getElementById('diagnosis')!;
    const diagLines = [...diagEl.querySelectorAll('.diag-line')].map(el => el.textContent ?? '');
    if (diagLines.length > 0) {
      lines.push('## 診断');
      diagLines.forEach(l => lines.push(l));
      lines.push('');
    }

    return lines.join('\n');
  }

  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(generateMarkdown());
      copyBtn.textContent = '✓ コピー完了';
      setTimeout(() => { copyBtn.textContent = '📋 MD コピー'; }, 2000);
    } catch {
      copyBtn.textContent = '✗ 失敗';
      setTimeout(() => { copyBtn.textContent = '📋 MD コピー'; }, 2000);
    }
  });

  downloadBtn.addEventListener('click', () => {
    const blob = new Blob([generateMarkdown()], { type: 'text/markdown;charset=utf-8' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `interval-quiz-${new Date().toISOString().slice(0, 10)}.md`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // ---- CSV エクスポート ----
  function generateCsv(): string {
    const header = 'id,sessionId,playedAt,lastPlayedAt,answeredAt,responseTimeMs,replayCount,baseMidi,baseNote,directionMode,rangeMin,rangeMax,correctSt,answeredSt,ok';
    const rows = loadRecords().map(r =>
      [r.id, r.sessionId, r.playedAt, r.lastPlayedAt, r.answeredAt, r.responseTimeMs,
       r.replayCount, r.baseMidi, `"${r.baseNote}"`, r.directionMode,
       r.rangeMin, r.rangeMax, r.correctSt, r.answeredSt, r.ok].join(',')
    );
    return [header, ...rows].join('\n');
  }

  csvBtn.addEventListener('click', () => {
    const blob = new Blob([generateCsv()], { type: 'text/csv;charset=utf-8' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `interval-quiz-${new Date().toISOString().slice(0, 10)}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  });

  // ---- 初期表示 ----
  renderStats();
  updateButtonConstraints();

  playBtn.addEventListener('click', () => { if (!isPlaying) newQuestion(); });
  replayBtn.addEventListener('click', () => {
    if (isPlaying) return;
    answered = false;
    currentReplayCount++;
    resetAnswerButtons();
    play(currentSemitones, currentBaseMidi);
  });

  directionSelect.addEventListener('change', updateButtonConstraints);

  function onRangeChange(): void {
    rangeMax = Math.max(1, Math.min(12, Number(rangeMaxInput.value) || 12));
    rangeMaxInput.value = String(rangeMax);
    updateButtonConstraints();
  }
  rangeMaxInput.addEventListener('change', onRangeChange);
</script>
